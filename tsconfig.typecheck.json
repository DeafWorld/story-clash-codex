{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "plugins": []
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "server/**/*.ts",
    "protocol/**/*.ts",
    "protocol/**/*.json",
    "tests/**/*.ts",
    "playwright.config.ts",
    "instrumentation.ts",
    "instrumentation-client.ts",
    "sentry.server.config.ts",
    "sentry.edge.config.ts"
  ],
  "exclude": [
    "node_modules",
    "archive",
    "data",
    "cloudflare",
    "output",
    "test-results",
    ".next",
    "node_modules_bak*"
  ]
}
