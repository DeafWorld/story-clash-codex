{
  "name": "lump-zero",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run niche:build -- --all",
    "lint": "tsx scripts/lint.ts",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx scripts/run-tests.ts",
    "niche:create": "tsx scripts/create-niche.ts",
    "niche:generate": "tsx scripts/generate-pages.ts",
    "niche:build": "tsx scripts/build-niche.ts",
    "niche:check": "tsx scripts/run-checks.ts",
    "niche:score": "tsx scripts/score-niches.ts",
    "niche:archive": "tsx scripts/archive-niche.ts",
    "niche:export": "tsx scripts/export-static.ts",
    "deploy:cloudflare:check": "tsx scripts/deploy-cloudflare-check.ts",
    "deploy:cloudflare:preview": "tsx scripts/deploy-cloudflare.ts --preview --all",
    "deploy:cloudflare:production": "tsx scripts/deploy-cloudflare.ts --all",
    "playwright:install": "playwright install chromium"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "2.8.1",
    "zod": "4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.36.0",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "playwright": "1.58.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "wrangler": "4.63.0"
  }
}
